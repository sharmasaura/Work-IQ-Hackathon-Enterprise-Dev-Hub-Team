# Azure OpenAI / Foundry chat client
WORKIQ_AZURE_ENDPOINT=https://YOUR-RESOURCE.services.ai.azure.com
WORKIQ_MODEL=gpt-5-mini
WORKIQ_AZURE_API_VERSION=2024-08-01-preview
