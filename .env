# MCP stdio tool launch command
# Windows example:
WORKIQ_MCP_COMMAND=C:\Projects\workingHackathon\workiq-hackathon\.venv\Scripts\python.exe
WORKIQ_MCP_ARGS=simulator\server.py

# Work IQ simulator context
WORKIQ_SIM_PERSONA=quality_engineer
